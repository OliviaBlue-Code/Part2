<Window x:Class="demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MainWindow" Height="400" Width="700">
    <Grid>


        <Grid x:Name="home_grid"
              Visibility="Visible">
            <Image Source="/AImage.jpg" 
                   Height="200" 
                   Width="400" 
                   Margin="0,20,0,100"
                   />
            
            <TextBlock Text="Welcome to AEGISNODE, click continue button"
                       Height="20" 
                       Width="270" 
                       TextAlignment="Center" 
                       Margin="0,200,0,0"
                       FontFamily="Arial Rounded MT Bold"/>
            
            <Button Height="40"
                    Width="100" 
                    Margin="0,300,0,0" 
                    Background="Azure"
                    Content="Proceed"
                    Click="proceed"/>
        </Grid>

        <!-- USERNAME GRID - CENTERED -->
        <Grid.Background>
            <ImageBrush ImageSource="aibackground.jpg"/>
        </Grid.Background>

        <Grid x:Name="username_grid"
              Visibility="Hidden">
            
            <StackPanel 
                HorizontalAlignment="Center"
                VerticalAlignment="Center" 
                Width="300">
                <Image Source="/logo.png" 
                       Height="150"
                       Width="200"
                       Margin="0,0,0,20"/>

                <TextBlock Text="Enter username" 
                           Height="20" 
                           TextAlignment="Center"
                           FontFamily="Arial Rounded MT Bold"
                           Margin="0,0,0,10"/>

                <TextBox Height="40" 
                         TextAlignment="Center" 
                         FontFamily="Arial Rounded MT Bold"
                         x:Name="usernames_input" 
                         Margin="0,0,0,10"/>

                <TextBlock x:Name="errorTextBlock"
                           Visibility="Collapsed"
                           Text="please enter username to continue..."
                           Height="20" 
                           TextAlignment="Center"
                           Foreground="Red"
                           FontFamily="Arial Rounded MT Bold" Margin="0,0,0,10"/>

                <Button Height="40"
                        Content="Submit Username"
                        Click="submit_name"/>
            </StackPanel>
        </Grid>

        <Grid x:Name="chat_grid" 
              Visibility="Hidden">
            <ListView x:Name="chats"
                      Height="300" 
                      Margin="0,0,0,120"
                      Background="Aqua"/>
            
            <TextBox x:Name="question"
                     Height="50"
                     Width="450"
                     Margin="20,300,300,0"/>
            
            <Button Height="50"
                    Width="150"
                    Margin="450,300,0,0"
                    Content="Send" 
                    Click="send"/>
        </Grid>
    </Grid>
</Window>